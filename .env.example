# MongoDB connection string (use Atlas or local instance)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=travel-tracker

# Session secret (at least 32 chars) used to sign cookies
SESSION_SECRET=replace-with-a-very-secret-string

# Cookie name (optional)
COOKIE_NAME=sessionId

# NODE_ENV=development or production
NODE_ENV=development

